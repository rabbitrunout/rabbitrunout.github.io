{
  "extends": [
    "development"
  ],
  "hints": {
    "compat-api/css": [
      "default",
      {
        "ignore": [
          "scroll-behavior",
          "scroll-behavior: smooth",
          "inset",
          "min-height: auto",
          "backdrop-filter",
          "scrollbar-width",
          "scrollbar-width: none",
          "aspect-ratio",
          "scroll-behavior: auto"
        ]
      }
    ],
    "compat-api/html": [
      "default",
      {
        "ignore": [
          "meta[name=theme-color]"
        ]
      }
    ],
    "meta-viewport": "off",
    "manifest-file-extension": "off",
    "apple-touch-icons": "off"
  }
}